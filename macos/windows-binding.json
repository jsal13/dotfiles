{
  "title": "Visual Studio Code",
  "rules": [
    {
      "description": "Change left-control to command if pressed in VSCode",
      "manipulators": [
        {
          "conditions": [
            {
              "bundle_identifiers": [
                "com\\.microsoft\\.VSCode",
                "com\\.microsoft\\.VSCodeInsiders"
              ],
              "type": "frontmost_application_if"
            }
          ],
          "from": {
            "key_code": "left_control",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_command"
            }
          ],
          "type": "basic"
        }
      ]
    }
  ]
}
